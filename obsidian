#!/usr/bin/env bash
# =============================================================================
# Obsidian Security Suite — Unified CLI
# One command to protect your servers: firewall, file integrity,
# malware detection, bot blocking, health monitoring, and multi-server sync
#
# Usage: obsidian <module> <command> [options]
#
# Modules:
#   ban       — IP ban management (ban, unban, list, history, import, export)
#   scan      — File integrity scanning (baseline, full, verify, monitor)
#   malware   — Malware & cryptominer detection (scan, processes, crons, quarantine)
#   bots      — Bot detection & blocking (analyze, scan-ua, scanners, auto-ban)
#   health    — System health monitoring (check, cpu, memory, disk, php, connections)
#   whitelist — IP whitelist management (add, remove, list, cleanup)
#   alert     — Alert management (test, history)
#   agent     — Sync agent control (start, stop, status)
#   status    — Overall Obsidian status
# =============================================================================

set -euo pipefail

# Resolve installation directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export OBSIDIAN_DIR="${OBSIDIAN_DIR:-${SCRIPT_DIR}}"
export OBSIDIAN_DATA="${OBSIDIAN_DATA:-${OBSIDIAN_DIR}/data}"
export OBSIDIAN_LOGS="${OBSIDIAN_LOGS:-${OBSIDIAN_DIR}/logs}"
export OBSIDIAN_RUN="${OBSIDIAN_RUN:-/var/run/obsidian}"

# Source all libraries
source "${OBSIDIAN_DIR}/lib/common.sh"
source "${OBSIDIAN_DIR}/lib/banner.sh"
source "${OBSIDIAN_DIR}/lib/alert.sh"
source "${OBSIDIAN_DIR}/lib/whitelist.sh"
source "${OBSIDIAN_DIR}/lib/firewall.sh"
source "${OBSIDIAN_DIR}/lib/monitor.sh"
source "${OBSIDIAN_DIR}/lib/correlate.sh"
source "${OBSIDIAN_DIR}/lib/malware.sh"
source "${OBSIDIAN_DIR}/lib/botguard.sh"
source "${OBSIDIAN_DIR}/lib/health.sh"
source "${OBSIDIAN_DIR}/lib/audit.sh"

# Load config if exists
load_config 2>/dev/null || true
init_directories 2>/dev/null || true

